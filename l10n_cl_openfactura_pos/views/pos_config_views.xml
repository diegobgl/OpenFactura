<odoo>
    <record id="view_pos_config_form_openfactura" model="ir.ui.view">
        <field name="name">pos.config.form.openfactura</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Openfactura">
                    <group>
                        <field name="openfactura_enabled"/>
                        <field name="openfactura_default_document_type"/>
                        <field name="openfactura_allow_receipt"/>
                        <field name="openfactura_allow_invoice"/>
                        <field name="openfactura_force_partner_for_invoice"/>
                        <field name="openfactura_branch_code"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
