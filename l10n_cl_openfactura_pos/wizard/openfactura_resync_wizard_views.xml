<odoo>
    <record id="view_openfactura_resync_wizard" model="ir.ui.view">
        <field name="name">openfactura.resync.wizard.form</field>
        <field name="model">openfactura.resync.wizard</field>
        <field name="arch" type="xml">
            <form string="Resync Openfactura">
                <group>
                    <field name="company_id"/>
                    <field name="sync_catalogs"/>
                    <field name="sync_partners"/>
                </group>
                <footer>
                    <button name="action_resync" type="object" string="Run" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
