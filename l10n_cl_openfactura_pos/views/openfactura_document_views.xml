<odoo>
    <record id="view_openfactura_document_search" model="ir.ui.view">
        <field name="name">openfactura.document.search</field>
        <field name="model">openfactura.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="company_id"/>
                <field name="source_channel"/>
                <field name="document_type"/>
                <field name="state"/>
                <filter string="POS" name="f_pos" domain="[('source_channel','=','pos')]"/>
                <filter string="Facturación" name="f_acc" domain="[('source_channel','=','account_move')]"/>
                <filter string="Errores" name="f_err" domain="[('state','in',('retry','error','rejected'))]"/>
            </search>
        </field>
    </record>

    <record id="view_openfactura_document_tree" model="ir.ui.view">
        <field name="name">openfactura.document.tree</field>
        <field name="model">openfactura.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="source_channel"/>
                <field name="document_type"/>
                <field name="state"/>
                <field name="folio"/>
                <field name="number"/>
                <field name="response_code"/>
                <field name="sent_at"/>
            </list>
        </field>
    </record>

    <record id="view_openfactura_document_form" model="ir.ui.view">
        <field name="name">openfactura.document.form</field>
        <field name="model">openfactura.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_retry" type="object" string="Retry" class="btn-primary"/>
                    <button name="action_refresh_status" type="object" string="Refresh Status"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="source_channel"/>
                        <field name="source_model"/>
                        <field name="source_res_id"/>
                        <field name="pos_order_id"/>
                        <field name="account_move_id"/>
                        <field name="document_type"/>
                        <field name="external_id"/>
                        <field name="folio"/>
                        <field name="number"/>
                        <field name="idempotency_key" readonly="1"/>
                        <field name="error_message"/>
                    </group>
                    <notebook>
                        <page string="Payloads">
                            <field name="request_payload" widget="text"/>
                            <field name="response_payload" widget="text"/>
                        </page>
                        <page string="Attachments">
                            <field name="pdf_attachment_id"/>
                            <field name="xml_attachment_id"/>
                            <field name="json_attachment_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_openfactura_document" model="ir.actions.act_window">
        <field name="name">Openfactura Documents</field>
        <field name="res_model">openfactura.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_openfactura_document_search"/>
    </record>
</odoo>
