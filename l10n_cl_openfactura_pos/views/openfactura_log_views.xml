<odoo>
    <record id="view_openfactura_log_tree" model="ir.ui.view">
        <field name="name">openfactura.log.tree</field>
        <field name="model">openfactura.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="created_at"/>
                <field name="company_id"/>
                <field name="operation"/>
                <field name="response_status"/>
                <field name="duration_ms"/>
                <field name="level"/>
                <field name="correlation_id"/>
            </tree>
        </field>
    </record>
    <record id="view_openfactura_log_form" model="ir.ui.view">
        <field name="name">openfactura.log.form</field>
        <field name="model">openfactura.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="operation"/>
                        <field name="company_id"/>
                        <field name="request_url"/>
                        <field name="request_method"/>
                        <field name="request_headers_sanitized" widget="text"/>
                        <field name="request_body" widget="text"/>
                        <field name="response_status"/>
                        <field name="response_body" widget="text"/>
                        <field name="error_message" widget="text"/>
                        <field name="duration_ms"/>
                        <field name="correlation_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_openfactura_log" model="ir.actions.act_window">
        <field name="name">Openfactura Logs</field>
        <field name="res_model">openfactura.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
