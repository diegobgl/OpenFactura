<odoo>
    <record id="view_move_form_openfactura" model="ir.ui.view">
        <field name="name">account.move.form.openfactura</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_openfactura_emit" type="object" string="Emitir Openfactura" class="btn-primary" invisible="move_type not in ('out_invoice','out_refund')"/>
                <button name="action_openfactura_check_status" type="object" string="Consultar Estado" invisible="not openfactura_document_id"/>
                <button name="action_openfactura_retry" type="object" string="Reintentar" invisible="not openfactura_document_id"/>
                <button name="action_openfactura_download_pdf" type="object" string="Descargar PDF" invisible="not openfactura_document_id"/>
                <button name="action_openfactura_open_document" type="object" string="Ver Documento Openfactura" invisible="not openfactura_document_id"/>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Openfactura">
                    <group>
                        <field name="openfactura_document_type"/>
                        <field name="openfactura_document_id" readonly="1"/>
                        <field name="openfactura_state" readonly="1"/>
                        <field name="openfactura_external_folio" readonly="1"/>
                        <field name="openfactura_error_message" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
