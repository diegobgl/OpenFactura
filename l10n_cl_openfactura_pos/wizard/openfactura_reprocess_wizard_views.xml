<odoo>
    <record id="view_openfactura_reprocess_wizard" model="ir.ui.view">
        <field name="name">openfactura.reprocess.wizard.form</field>
        <field name="model">openfactura.reprocess.wizard</field>
        <field name="arch" type="xml">
            <form string="Reprocess Openfactura Document">
                <group><field name="document_id"/></group>
                <footer>
                    <button name="action_reprocess" type="object" string="Reprocess" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
